{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "XNAT Helm chart values",
  "description": "Intentionally permissive: type-checks the most error-prone keys (booleans, counts, the new resource/jvm/pdb/probe blocks) without forbidding the many additional keys consumers legitimately set (external CNPG, redis image overrides, plugin/authplugin maps, extra volumes). No properties are required and unknown keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 0 },
    "imagePullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
    "imagePullSecrets": { "type": ["array", "null"] },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "namespace": { "type": "string" },
    "containerService": { "type": "boolean" },
    "createConfigSecret": { "type": "boolean" },
    "restore": { "type": "boolean" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": ["string", "number"] }
      }
    },
    "resources": { "type": "object", "additionalProperties": true },
    "lifecycle": { "type": "object", "additionalProperties": true },
    "securityContext": { "type": "object", "additionalProperties": true },
    "podSecurityContext": { "type": "object", "additionalProperties": true },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "probes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "startup": { "type": "object", "additionalProperties": true },
        "liveness": { "type": "object", "additionalProperties": true },
        "readiness": { "type": "object", "additionalProperties": true }
      }
    },
    "jvm": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minHeap": { "type": "string" },
        "maxHeap": { "type": "string" },
        "maxMetaspace": { "type": "string" },
        "extraOpts": { "type": "string" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxUnavailable": { "type": ["integer", "string"] },
        "minAvailable": { "type": ["integer", "string"] }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "port": { "type": "integer" },
        "type": { "type": "string" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "redis": { "type": "object", "additionalProperties": true },
    "cnpg": { "type": "object", "additionalProperties": true },
    "activemq": { "type": "object", "additionalProperties": true },
    "mail": { "type": "object", "additionalProperties": true },
    "volumes": { "type": "object", "additionalProperties": true },
    "persistence": { "type": "object", "additionalProperties": true },
    "plugins": { "type": ["object", "array"] },
    "authplugins": { "type": ["object", "array"] },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "jmx": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "port": { "type": "integer" },
            "image": { "type": "string" },
            "agentJarPath": { "type": "string" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" }
          }
        }
      }
    }
  }
}
